        </elementProp>
      </ThreadGroup>
      <hashTree>
        <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Test User Sequential Variable">
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="script">def threadId = ctx.getThreadNum()
def userPrefix = vars.get(&quot;TEST_USER_PREFIX&quot;)
def maxUsers = vars.get(&quot;TEST_USERS&quot;) as int
def threadUser = userPrefix + ((threadId % maxUsers) + 1)

vars.put(&quot;TEST_USER&quot;, threadUser)
</stringProp>
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="TestPlan.comments">This script sets the TEST_USER variable in a sequential order (user_prefix1, user_prefix2, etc.)</stringProp>
        </JSR223PreProcessor>
        <hashTree/>
        <RandomVariableConfig guiclass="TestBeanGUI" testclass="RandomVariableConfig" testname="Test User Random Variable" enabled="false">
          <stringProp name="maximumValue">${TEST_USERS}</stringProp>
          <stringProp name="minimumValue">1</stringProp>
          <stringProp name="outputFormat">${TEST_USER_PREFIX}##</stringProp>
          <boolProp name="perThread">true</boolProp>
          <stringProp name="randomSeed"></stringProp>
          <stringProp name="variableName">TEST_USER</stringProp>
          <stringProp name="TestPlan.comments">This sets the user as a random username from the number of setup users</stringProp>
        </RandomVariableConfig>
