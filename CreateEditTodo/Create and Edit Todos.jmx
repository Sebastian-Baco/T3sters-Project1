                <stringProp name="Argument.value">{ &quot;username&quot;: &quot;${TEST_USER_PREFIX}${TEST_USER_INDEX}&quot;, &quot;password&quot;: &quot;${TEST_USER_PASSWORD}&quot; }&#xd;
